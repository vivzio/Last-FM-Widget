LAST_FM_USERNAME=       # Your Last.FM username (Unless you want to have someone else's stats...)
API_KEY=                # Last.FM API key (https://last.fm/api/account/create)
APPLICATION_ID=         # Discord Application ID (https://discord.com/developers/applications > Your application > General Information > Application ID)
BOT_TOKEN=              # Discord Bot Token (https://discord.com/developers/applications > Your application > Bot > Token)
USER_ID=                # Discord User ID (https://discord.com/app > Click your profile > Copy User ID (You may need to enable Developer Mode in the Settings))